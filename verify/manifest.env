# Tinder MVP — deploy manifest for CI/e2e verification
# Source this file before running acceptance tests.
# Usage: source verify/manifest.env && eval "$TEST_DEPS" && eval "$UP" && eval "$MIGRATE" && eval "$READY" && eval "$ACCEPTANCE"; eval "$DOWN"

# Build and start the stack
UP="docker compose up --build -d"

# Run database migrations (required — fresh postgres has no tables)
MIGRATE="alembic upgrade head"

# Wait for readiness — retry up to 30s on any error
READY="curl -sf --retry 30 --retry-all-errors --retry-delay 1 http://localhost:${APP_PORT:-8020}/healthz"

# Run acceptance tests against the live system
ACCEPTANCE="API_BASE_URL=http://localhost:${APP_PORT:-8020} pytest verify/acceptance/ -v"

# Tear down with volume removal
DOWN="docker compose down -v"

# Install test dependencies (app + dev extras) — escaped brackets for eval safety
TEST_DEPS="pip install .\[dev\]"
