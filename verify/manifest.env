# Tinder MVP — deploy manifest for CI/e2e verification
# Source this file before running acceptance tests.
# Usage: source verify/manifest.env && eval "$TEST_DEPS" && eval "$UP" && eval "$READY" && eval "$ACCEPTANCE"; eval "$DOWN"

# Bring the stack up with build (no cache for CI)
UP="docker compose up --build -d"

# Wait for readiness — retry up to 30s
READY="curl -sf --retry 30 --retry-connrefused --retry-delay 1 http://localhost:${APP_PORT:-8020}/healthz"

# Run acceptance tests against the live system
ACCEPTANCE="pytest verify/acceptance/ -v"

# Tear down with volume removal
DOWN="docker compose down -v"

# Install test dependencies (app + dev extras)
TEST_DEPS="pip install '.[dev]'"
