# Tinder MVP — environment variables
# Copy this file to .env and adjust for your environment.
# The app reads these via pydantic-settings.

# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://tinder:tinder@localhost:5432/tinder

# Redis connection (async)
REDIS_URL=redis://localhost:6379/0

# Host port published by compose (in-container is always 8000)
APP_PORT=8020

# Bind address
HOST=0.0.0.0

# Log level: debug | info | warning | error
LOG_LEVEL=info
